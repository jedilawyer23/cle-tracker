# Firebase web app config (Project settings -> General -> Your apps -> SDK setup and config).
# Copy this file to .env.local and fill in real values once the Firebase project exists.
# .env.local is gitignored — never commit real values.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_USE_EMULATOR=false
