{
  "compilerOptions": {
    "module": "ES2022",
    "moduleResolution": "bundler",
    "target": "ES2022",
    "outDir": "lib",
    "rootDir": "..",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "paths": { "@domain/*": ["../src/domain/*"] }
  },
  "include": ["src", "../src/domain"],
  "exclude": ["src/**/*.test.ts", "src/**/*.e2e.test.ts", "../src/domain/__tests__"]
}
